# ── Database ──────────────────────────────────────────────────────────────────
# Neon (free): https://neon.tech → create project → copy connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Redis / BullMQ ────────────────────────────────────────────────────────────
# Upstash (free): https://upstash.com → create Redis DB → copy REST URL
# Use the "redis://" connection string from the "Connect" tab
REDIS_URL="redis://default:password@host:6379"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="64-byte-random-hex-string"
JWT_REFRESH_SECRET="another-64-byte-random-hex-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ── AI — caption generation ───────────────────────────────────────────────────
# Groq (primary — free tier): https://console.groq.com → API Keys → create key
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"   # optional override

# OpenRouter (fallback): https://openrouter.ai/settings/keys → Create Key
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct"   # optional override

# Cloudflare Workers AI (image generation fallback)
# https://dash.cloudflare.com → Workers AI → Use REST API → Create API Token
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""

# ── Meta / Facebook ───────────────────────────────────────────────────────────
# https://developers.facebook.com → My Apps → create app → Settings → Basic
META_APP_ID=""
META_APP_SECRET=""
META_WEBHOOK_VERIFY_TOKEN="choose-a-secret-token"

# ── Google OAuth ──────────────────────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://your-api-domain.com/v1/platforms/callback/google"

# ── OTP (leave empty to use mock OTP=1234 in dev) ────────────────────────────
OTP_PROVIDER=""          # "twilio" | "msg91" | "" (empty = mock)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
MSG91_AUTH_KEY=""
MSG91_TEMPLATE_ID=""

# ── File Storage ──────────────────────────────────────────────────────────────
# Cloudflare R2 (free 10 GB): https://dash.cloudflare.com → R2 → create bucket
#   S3_ENDPOINT = https://<account_id>.r2.cloudflarestorage.com
#   AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY = R2 API token key+secret
#
# AWS S3 (paid): set AWS_REGION + S3_BUCKET, leave S3_ENDPOINT empty
#
# Leave ALL blank to use local disk (dev only — files lost on Render restart)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="auto"
S3_BUCKET="socialgenie-assets"
S3_ENDPOINT=""           # R2 endpoint or leave empty for AWS S3
CLOUDFRONT_DOMAIN=""     # Optional CDN / R2 public domain for faster URLs

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"
API_BASE_URL="http://localhost:3001"
